    def doitan(self, target_pos, target_face):
        if self.body1_pos is None or target_pos is None or self.face is None or target_face >
            return

        STOP_DISTANCE = 0.0
        DIST_TOL = 0.10

        STRAIGHT_DEADBAND = 8.0
        STEER_DEADBAND = 25.0
        BACKUP_DEADBAND = 6.0

        FACE_DEADBAND = 2.0

        distance = distancebet(self.body1_pos, target_pos)
        dist_error = distance - STOP_DISTANCE

        # Only drive to position if we have not already reached it.
        if not self.orient:
            target_angle = anglebet(self.body1_pos, target_pos)
            drive_error = normalize_angle_deg(target_angle - self.face)

            if abs(dist_error) <= DIST_TOL:
                send_command("F 0")
                self.last_cmd = "F 0"
                self.orient = True
                print("Position reached. Now aligning orientation.")
                return

            move_speed = int(min(180, max(80, abs(dist_error) * 250)))

            if dist_error > 0:
                if abs(drive_error) <= STRAIGHT_DEADBAND:
                    cmd = f"F {move_speed}"
                elif abs(drive_error) <= STEER_DEADBAND:
                    if drive_error > 0:
                        cmd = f"FL {move_speed}"
                    else:
                        cmd = f"FR {move_speed}"
                else:
                    turn_speed = int(min(100, max(50, abs(drive_error) * 0.8)))
                    if drive_error > 0:
                        cmd = f"L {turn_speed}"
                    else:
                        cmd = f"R {turn_speed}"
            else:
                if abs(drive_error) <= BACKUP_DEADBAND:
                    cmd = f"B {move_speed}"
                else:
                    turn_speed = int(min(100, max(50, abs(drive_error) * 0.8)))
                    if drive_error > 0:
                        cmd = f"L {turn_speed}"
                    else:
                        cmd = f"R {turn_speed}"

        else:
            # Orientation-only mode.
            # Do not check position anymore here.
            face_error = normalize_angle_deg(target_face - self.face)

            print("Aligning orientation. face =", self.face, "target =", target_face, "error>

            if abs(face_error) <= FACE_DEADBAND:
                cmd = "F 0"
                self.done = True
                self.ridsetb = False
                self.aligning_orientation = False
                print("Reached saved position and orientation")

            else:
                turn_speed = int(min(70, max(35, abs(face_error) * 0.6)))

                if face_error > 0:
                    cmd = f"L {turn_speed}"
                else:
                    cmd = f"R {turn_speed}"

        if cmd != self.last_cmd:
            send_command(cmd)
            self.last_cmd = cmd



    def itdo(self,target):

        if self.body1_pos is None or target is None or self.face is None:
            return

        xb = self.body1_pos[0]
        yb = self.body1_pos[1]
        zb = self.body1_pos[2]
        xw = target[0]
        yw = target[1]
        zw = target[2]
        roll = self.body1an[0]
        pitch = self.body1an[1] + 44
        yaw = self.body1an[2]
        direc = self.face - 180
        distance = distancebet(self.body1_pos, target)


        target_angle = anglebet(self.body1_pos, target)
        error = normalize_angle_deg(target_angle - direc)

        STOP_DISTANCE = 0.6050
      # 2 feet in meters
        DIST_TOL = 0.01             # about 5 cm tolerance
        TURN_ONLY_DEADBAND = .5   # must face target fairly well before moving
        BACKUP_DEADBAND = 1.5       # your original angle deadband
        STRAIGHT_DEADBAND = 6.0
        STEER_DEADBAND = 0
        dist_error = distance - STOP_DISTANCE

        if abs(dist_error) <= DIST_TOL:
            cmd = "B 0"
            turn_speed = int(min(self.max_speed, max(self.min_speed, abs(error) * self.kp)))
            if error > 0:
                cmd = f"L {turn_speed}"
            elif error > 0:
                cmd = f"R {turn_speed}"
            else:
                cmd = "B 0"
                if self.state:
                    send_command("B 0")
                    cmd = "bump"
                    time.sleep(3)
                    self.state = False

        else:
            move_speed = int(min(255, max(90, abs(dist_error) * 300)))

            if dist_error > 0:
                # too far away: move toward target
                if abs(error) <= STRAIGHT_DEADBAND:
                    cmd = f"B {move_speed}"

                elif abs(error) <= STEER_DEADBAND:
                    if error > 0:
                        cmd = f"BR {move_speed}"
                    else:
                        cmd = f"BL {move_speed}"

                else:
                    turn_speed = int(min(self.max_speed, max(self.min_speed, abs(error) * se>
                    if error > 0:
                        cmd = f"L {turn_speed}"
                    else:
                        cmd = f"R {turn_speed}"

            else:
                # too close: only back up if aligned closely enough
                if abs(error) <= BACKUP_DEADBAND:
                    cmd = f"F {move_speed}"
                else:
                    turn_speed = int(min(self.max_speed, max(self.min_speed, abs(error) * se>
                    if error > 0:
                        cmd = f"L {turn_speed}"
                    else:
                        cmd = f"R {turn_speed}"


        if cmd != self.last_cmd:
            send_command(cmd)
            self.last_cmd = cmd




    def doit(self,target):

        if self.body1_pos is None or target is None or self.face is None:
            return

        xb = self.body1_pos[0]
        yb = self.body1_pos[1]
        zb = self.body1_pos[2]
        xw = target[0]
        yw = target[1]
        zw = target[2]
        roll = self.body1an[0]
        pitch = self.body1an[1] + 44
        yaw = self.body1an[2]
        direc = self.face
        distance = distancebet(self.body1_pos, target)


        target_angle = anglebet(self.body1_pos, target)
        error = normalize_angle_deg(target_angle - direc)

        if self.ridset5 or self.ridsetb:
            STOP_DISTANCE = 0
        else:
            STOP_DISTANCE = 0.9096
        DIST_TOL = 0.05             # about 5 cm tolerance
        TURN_ONLY_DEADBAND = 12.0   # must face target fairly well before moving
        BACKUP_DEADBAND = 3.0       # your original angle deadband
        STRAIGHT_DEADBAND = 6.0
        STEER_DEADBAND = 25.0
        dist_error = distance - STOP_DISTANCE
        if abs(dist_error) <= DIST_TOL:
            cmd = "F 0"
            self.done= True
            turn_speed = int(min(self.max_speed, max(self.min_speed, abs(error) * self.kp)))
            if error > 0 and not self.ridset5:
                cmd = f"L {turn_speed}"
            elif error > 0 and not self.ridset5:
                cmd = f"R {turn_speed}"
            else:
                cmd = "F 0"

        else:
            move_speed = int(min(255, max(90, abs(dist_error) * 300)))

            if dist_error > 0:
                # too far away: move toward target
                if abs(error) <= STRAIGHT_DEADBAND:
                    cmd = f"F {move_speed}"

                elif abs(error) <= STEER_DEADBAND:
                    if error > 0:
                        cmd = f"FL {move_speed}"
                    else:
                        cmd = f"FR {move_speed}"

                else:
                    turn_speed = int(min(self.max_speed, max(self.min_speed, abs(error) * se>
                    if error > 0:
                        cmd = f"L {turn_speed}"
                    else:
                        cmd = f"R {turn_speed}"

            else:
                # too close: only back up if aligned closely enough
                if abs(error) <= BACKUP_DEADBAND:
                    cmd = f"B {move_speed}"
                else:
                    turn_speed = int(min(self.max_speed, max(self.min_speed, abs(error) * se>
                    if error > 0:
                        cmd = f"L {turn_speed}"
                    else:
                        cmd = f"R {turn_speed}"

        if cmd != self.last_cmd:
            send_command(cmd)
            self.last_cmd = cmd

    def scoop(self):
        if self.filling:
            send_command("set")
            time.sleep(.2)
            send_command("arm -3")
            time.sleep(.2)
            send_command("F 90")
            time.sleep(3)
            send_command("pick")
            time.sleep(1)
            send_command("F 0")
            send_command("asc 110")
            time.sleep(.7)
            send_command("scp 80")
            time.sleep(2)
            send_command("B 50")
            time.sleep(1)
            send_command("B 0")
            send_command("pick")
            self.state = True

            self.filling = False

    def go(self):
        if not self.goo:
            return

        if self.step == 1:
            self.ridset3 = True
            self.ridset2 = False
            self.ridset5 = False
            self.follow4 = False

            self.doit(self.setpos3)

            if self.done:
                self.ridset3 = False
                self.done = False
                self.last_cmd = None
                self.step = 2
                print("Step 1 done, going to step 2")

        elif self.step == 2:
            self.ridset2 = False
            self.ridset3 = False
            self.ridset5 = False
            self.follow4 = False

            self.filling = True
            self.scoop()
            self.filling = True
            self.scoop()
            self.step = 3
            print("Step 2 done, going to step 3")

        elif self.step == 3:
            self.ridset2 = True
            self.ridset3 = False
            self.ridset5 = False
            self.follow4 = False

            self.doit(self.setpos2)

            if self.done:
                self.ridset2 = False
                self.done = False
                self.last_cmd = None
                self.step = 4
                print("Step 3 done, going to step 4")

        elif self.step == 4:
            self.ridset2 = False
            self.ridset3 = False
            self.ridset5 = False
            self.follow4 = False

            self.filling = True
            self.scoop()
            self.filling = True
            self.scoop()
            self.step = 5
            print("Step 4 done, going to step 5")
            self.orient = False

        elif self.step == 5:
            self.ridset2 = False
            self.ridset3 = False
            self.ridsetb = True
            self.follow4 = False

            self.doitan(self.setbos,self.setbosan)

            if self.done:
                self.ridset5 = False
                self.done = False
                self.last_cmd = None
                self.step = 6
                print("Step 5 done, going to step 6")

        elif self.step == 6:
            self.ridset2 = False
            self.ridset3 = False
            self.ridset5 = False
            self.follow4 = True

            self.itdo(self.body4_pos)

            if self.state == False:
                self.follow4 = False
                self.last_cmd = None
                self.step = 7
                self.orient = False
                print("Step 6 done, going to step 7")
                self.done = False

        elif self.step == 7:
            self.ridset2 = False
            self.ridset3 = False
            self.ridsetb = True
            self.follow4 = False

            self.doit(self.setbos)

            if self.done:
                self.ridsetb = False
                self.done = False
                self.last_cmd = None
                self.step = 1
                send_command("F 0")
                print("Go sequence complete")



def keyboard_loop(node):
    try:
        while True:
            cmd = input("Enter command (follow, S, q, or Arduino cmd): ").strip()

            if cmd.lower() == "q":
                send_command("F 0")
                rclpy.shutdown()
                break
            elif cmd.lower() == "go":
                node.follow2 = False
                node.follow3 = False
                node.follow4 = False
                node.follow5 = False
                node.ridset2 = False
                node.ridset3 = False
                node.ridset5 = False
                node.filling = False
                node.last_cmd = None
                node.done = False
                node.step = 1
                node.goo = True
                print("Go sequence ON")

            elif cmd.lower() == "rid2":
                node.follow2 = True
                node.follow3 = False
                node.follow4 = False
                node.filling = False
                node.ridset2 = False
                node.ridset3 = False
                node.ridset5 = False
                print("Follow mode ON")


            elif cmd.lower() == "rid3":
                node.follow3 = True
                node.follow2 = False
                node.follow4 = False
                node.filling = False
                node.ridset2 = False
