    def pose_callback_1(self, msg):
        self.body1_pos = (
            msg.pose.position.x,
            msg.pose.position.y,
            msg.pose.position.z
        )
        qx = msg.pose.orientation.x
        qy = msg.pose.orientation.y
        qz = msg.pose.orientation.z
        qw = msg.pose.orientation.w

        self.body1an = roll, pitch, yaw = quaternion_to_euler_degrees(qx, qy, qz, qw)
        self.face = facing(qx, qy, qz, qw)

        if self.setb:
            self.setbos = (
                msg.pose.position.x,
                msg.pose.position.y,
                msg.pose.position.z
            )
            self.setbosan = self.face

            self.setb = False


        if self.goo:
            self.go()
        elif self.follow2:
            self.doit(self.body2_pos)
        elif self.follow3:
            self.doit(self.body3_pos)
        elif self.ridset2:
            self.doit(self.setpos2)
        elif self.ridset3:
            self.doit(self.setpos3)
        elif self.ridset5:
            self.doit(self.setpos5)
        elif self.ridsetb:
            self.doitan(self.setbos, self.setbosan)
