def send_command(cmd):
    ser.write((cmd + "\n").encode("utf-8"))

def quaternion_to_euler_degrees(x, y, z, w):
    # roll (x-axis rotation)
    sinr_cosp = 2 * (w * x + y * z)
    cosr_cosp = 1 - 2 * (x * x + y * y)
    roll = math.atan2(sinr_cosp, cosr_cosp)

    # pitch (y-axis rotation)
    sinp = 2 * (w * y - z * x)
    if abs(sinp) >= 1:
        pitch = math.copysign(math.pi / 2, sinp)
    else:
        pitch = math.asin(sinp)

    # yaw (z-axis rotation)
    siny_cosp = 2 * (w * z + x * y)
    cosy_cosp = 1 - 2 * (y * y + z * z)
    yaw = math.atan2(siny_cosp, cosy_cosp)

    return (
        math.degrees(roll),
        math.degrees(pitch),
        math.degrees(yaw)
    )

def distancebet(body1_pos, body2_pos):
    x1, y1, z1 = body1_pos
    x2, y2, z2 = body2_pos

    dx = x2 - x1
    dy = y2 - y1
    dz = z2 - z1

    return math.sqrt(dx**2 + dy**2 + dz**2)

def anglebet(body1_pos, body2_pos):
    x1, _, z1 = body1_pos
    x2, _, z2 = body2_pos

    dx = x2 - x1
    dz = z2 - z1

    angle_deg = -math.degrees(math.atan2(dz, dx))

    while angle_deg > 180:
        angle_deg -= 360
    while angle_deg < -180:
        angle_deg += 360

    return angle_deg

def normalize_angle_deg(angle):
    while angle > 180:
        angle -= 360
    while angle < -180:
        angle += 360
    return angle

def facing(qx, qy, qz, qw):
    fx = 1 - 2*(qy*qy + qz*qz)
    fz = 2*(qx*qz - qw*qy)

    angle_deg = -math.degrees(math.atan2(fz, fx))

    while angle_deg > 180:
        angle_deg -= 360
    while angle_deg < -180:
        angle_deg += 360

    return angle_deg

