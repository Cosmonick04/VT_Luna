def main():
    rclpy.init()
    node = PositionReader()

    input_thread = threading.Thread(target=keyboard_loop, args=(node,), daemon=True)
    input_thread.start()

    try:
        rclpy.spin(node)
    finally:
        node.destroy_node()
        rclpy.shutdown()
        ser.close()

if __name__ == '__main__':
    main()
